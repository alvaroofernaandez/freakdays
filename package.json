{
  "name": "freak-days-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter freak-days dev:bootstrap",
    "dev:web": "pnpm --filter freak-days dev",
    "dev:api": "pnpm --filter freak-days-api start:dev",
    "dev:down": "pnpm --filter freak-days dev:down",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter freak-days typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.15",
      "simple-git": ">=3.36.0",
      "multer": ">=2.1.1",
      "serialize-javascript": ">=7.0.5",
      "rollup": ">=4.60.3",
      "postcss": ">=8.5.14",
      "yaml": ">=2.8.4",
      "lodash": ">=4.18.1",
      "node-forge": ">=1.4.0",
      "svgo": ">=4.0.1",
      "defu": ">=6.1.7",
      "devalue": ">=5.8.0",
      "seroval": ">=1.5.4",
      "effect": ">=3.20.0",
      "glob": ">=10.5.0",
      "webpack": ">=5.104.1",
      "h3": ">=1.15.11",
      "vite": ">=7.3.3",
      "minimatch@>=5.0.0 <6": ">=5.1.8",
      "minimatch@>=9.0.0": ">=9.0.7",
      "picomatch@>=2.0.0 <3": ">=2.3.2",
      "picomatch@>=4.0.0": ">=4.0.4",
      "brace-expansion@>=2.0.0 <3": ">=2.0.3",
      "uuid": ">=11.1.1"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.6.3",
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.5.3"
  }
}
